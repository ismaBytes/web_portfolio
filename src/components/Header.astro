---
import ThemeToggle from "./ThemeToggle.astro"
import LanguageToggle from "./LanguageToggle.astro"

import { t } from "../lib/translations";

const lang = Astro.url.pathname.includes("/eng") ? "en" : "es";

const base = import.meta.env.BASE_URL.replace(/\/$/, ""); 
const baseUrl = lang === "es" ? `${base}/esp/` : `${base}/eng/`;

const navItems = [
  {
    title: t(lang, "nav.experience"),
    titleKey: "nav.experience",
    ariaLabelKey: "nav.experience",
    label: "experience",
    url: `${baseUrl}/#experience`,
  },
  {
    title: t(lang, "nav.stack"),
    titleKey: "nav.stack",
    ariaLabelKey: "nav.stack",
    label: "stack",
    url: `${baseUrl}/#stack`,
  },
  {
    title: t(lang, "nav.about"),
    titleKey: "nav.about",
    ariaLabelKey: "nav.about",
    label: "about-me",
    url: `${baseUrl}/#about-me`,
  },
  {
    title: t(lang, "nav.contact"),
    titleKey: "nav.contact",
    ariaLabelKey: "nav.contact",
    label: "contacto",
    url: "mailto:ismabytes@gmail.com",
  },
]
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    class="flex px-3 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200 justify-center items-center"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-2 py-2 transition hover:text-blue-500 dark:hover:text-blue-500"
          aria-label={link.ariaLabelKey ? t(lang, link.ariaLabelKey) : link.label}
          href={link.url}
          data-i18n-key={link.titleKey}
          data-section={link.label}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
    <LanguageToggle />
  </nav>
</header>

<script>
  let isScrolling = false;

  const updateHeader = () => {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("a[data-section]");
    const nav = document.querySelector("header nav");

    if (!nav) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (isScrolling) return; // Ignore observer updates while a manual scroll is happening

        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              const isActive = link.getAttribute("data-section") === id;
              link.classList.toggle("text-blue-500", isActive);
              link.classList.toggle("dark:text-blue-400", isActive);
            });

            const hash = id === "home" ? "" : `#${id}`;
            const newUrl = hash ? hash : window.location.pathname;
            if (window.location.hash !== hash) {
              history.replaceState(null, "", newUrl);
            }
          }
        });
      },
      { threshold: 0.4 }
    );

    sections.forEach((section) => observer.observe(section));

    // Event delegation for clicks
    nav.onclick = (e) => {
      const link = (e.target as HTMLElement).closest("a[data-section]");
      if (!link) return;

      const sectionId = link.getAttribute("data-section");
      if (sectionId && sectionId !== "contacto") {
        e.preventDefault();
        const target = document.getElementById(sectionId);
        if (target) {
          isScrolling = true;
          
          // Update visual active state immediately
          navLinks.forEach((l) => {
            const isActive = l === link;
            l.classList.toggle("text-blue-500", isActive);
            l.classList.toggle("dark:text-blue-400", isActive);
          });

          const hash = sectionId === "home" ? "" : `#${sectionId}`;
          const newUrl = hash ? hash : window.location.pathname;
          history.replaceState(null, "", newUrl);
          
          target.scrollIntoView({ behavior: "smooth" });

          // Unlock after scroll finishes (roughly)
          setTimeout(() => {
            isScrolling = false;
          }, 800);
        }
      }
    };
  };

  document.addEventListener("astro:page-load", updateHeader);
</script>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  nav {
    @apply dark:bg-gray-800/90 bg-white/50;
  }

  @keyframes nav-shadown {
    0% {
      @apply dark:bg-gray-800/0 bg-white/0;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur ring-white/10;
    }
  }
</style>
