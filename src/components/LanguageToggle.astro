---
const lang = Astro.url.pathname.includes("/eng") ? "en" : "es";
const nextLang = lang === "es" ? "en" : "es";
const nextUrl = nextLang === "es" ? "/esp/" : "/eng/";
const label = nextLang === "es" ? "🇪🇸" : "🇬🇧";
---
<a
  href={nextUrl}
  class="ml-2 px-2 py-1 rounded text-sm bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition text-lg"
  aria-label={lang === "es" ? "Switch to English" : "Cambiar a Español"}
>
  {label}
</a>