---
const lang = Astro.url.pathname.includes("/eng") ? "en" : "es";
---
<div class="flex items-center gap-x-1 ml-4 border-l border-gray-300 dark:border-gray-700 pl-4">
  <a
    href="/esp/"
    class={`flex items-center justify-center w-8 h-8 rounded-lg transition-all duration-200 text-xl
      ${lang === 'es' 
        ? 'bg-blue-500/10 dark:bg-blue-400/10 ring-2 ring-blue-500/50 scale-110' 
        : 'opacity-50 hover:opacity-100 hover:bg-gray-200 dark:hover:bg-gray-800'}`}
    aria-label="Ver en Español"
    title="Español"
  >
    🇪🇸
  </a>
  <a
    href="/eng/"
    class={`flex items-center justify-center w-8 h-8 rounded-lg transition-all duration-200 text-xl
      ${lang === 'en' 
        ? 'bg-blue-500/10 dark:bg-blue-400/10 ring-2 ring-blue-500/50 scale-110' 
        : 'opacity-50 hover:opacity-100 hover:bg-gray-200 dark:hover:bg-gray-800'}`}
    aria-label="View in English"
    title="English"
  >
    🇬🇧
  </a>
</div>