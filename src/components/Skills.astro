---
import TitleSection from "./TitleSection.astro"
import CodeIcon from "./icons/Code.astro"
import TechLogo from "./TechLogo.astro"
import { t } from "../lib/translations"

const lang = Astro.url.pathname.includes("/eng") ? "en" : "es";

const FRONTEND = [
  { name: "HTML", slug: "html5" },
  { name: "CSS", slug: "css" },
  { name: "Javascript", slug: "javascript" },
  { name: "Angular", slug: "angular" },
  { name: "Vue.js", slug: "vuedotjs" },
  { name: "Nuxt", slug: "nuxt" },
]

const BACKEND = [
  { name: "Java", slug: "devbox" },
  { name: "Python", slug: "python" },
  { name: ".NET", slug: "dotnet" },
  { name: "SpringBoot", slug: "spring" },
  { name: "Maven", slug: "apachemaven" },
]

const TOOLS = [
  { name: "MySQL", slug: "mysql" },
  { name: "MariaDB", slug: "mariadb" },
  { name: "SQL Server", slug: "sqlite" },
  { name: "MongoDB", slug: "mongodb" },
  { name: "Git", slug: "git" },
  { name: "Azure Repos", slug: "bitbucket" },
  { name: "GitHub", slug: "github" },
  { name: "GitLab", slug: "gitlab" },
  { name: "CI/CD", slug: "githubactions" },
  { name: "Jira", slug: "jira" },
  { name: "Notion", slug: "notion" },
  { name: "Nginx", slug: "nginx" },
  { name: "SSH", slug: "gnubash" },
  { name: "SSL", slug: "letsencrypt" },
  { name: "Visual Studio Code", slug: "vscodium" },
  { name: "IntelliJ", slug: "intellijidea" },
  { name: "WebStorm", slug: "webstorm" },
]
---

<TitleSection>
  <CodeIcon class="size-7" />
  <span data-i18n-key="skills.techStack">{t(lang, "skills.techStack")}</span>
</TitleSection>

<div class="space-y-8 mt-8">
  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4" data-i18n-key="skills.frontend">{t(lang, "skills.frontend")}</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {FRONTEND.map(({ name, slug }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-all hover:scale-105 cursor-default">
          <TechLogo slug={slug} class="size-6 text-blue-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>

  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4" data-i18n-key="skills.backend">{t(lang, "skills.backend")}</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {BACKEND.map(({ name, slug }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-all hover:scale-105 cursor-default">
          <TechLogo slug={slug} class="size-6 text-green-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>

  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4" data-i18n-key="skills.generalTools">{t(lang, "skills.generalTools")}</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {TOOLS.map(({ name, slug }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-all hover:scale-105 cursor-default">
          <TechLogo slug={slug} class="size-6 text-purple-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>
</div>