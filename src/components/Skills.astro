---
import TitleSection from "./TitleSection.astro"
import CodeIcon from "./icons/Code.astro"
import JavaIcon from "./icons/Java.astro"
import ToolIcon from "./icons/Tool.astro"

const FRONTEND = [
  { name: "HTML", icon: CodeIcon },
  { name: "CSS", icon: CodeIcon },
  { name: "Javascript", icon: CodeIcon },
  { name: "Angular", icon: CodeIcon },
  { name: "Vue.js", icon: CodeIcon },
  { name: "Nuxt", icon: CodeIcon },
]

const BACKEND = [
  { name: "Java", icon: JavaIcon },
  { name: "Python", icon: JavaIcon },
  { name: "C#", icon: JavaIcon },
  { name: "SpringBoot", icon: JavaIcon },
  { name: "Maven", icon: JavaIcon },
]

const TOOLS = [
  { name: "MySQL", icon: ToolIcon },
  { name: "MariaDB", icon: ToolIcon },
  { name: "SQL Server", icon: ToolIcon },
  { name: "MongoDB", icon: ToolIcon },
  { name: "Git", icon: ToolIcon },
  { name: "Azure Repos", icon: ToolIcon },
  { name: "GitHub", icon: ToolIcon },
  { name: "GitLab", icon: ToolIcon },
  { name: "CI/CD", icon: ToolIcon },
  { name: "Jira", icon: ToolIcon },
  { name: "Notion", icon: ToolIcon },
  { name: "Nginx", icon: ToolIcon },
  { name: "SSH", icon: ToolIcon },
  { name: "SSL", icon: ToolIcon },
]
---

<TitleSection>
  <CodeIcon class="size-7" />
  Stack Tecnológico
</TitleSection>

<div class="space-y-8 mt-8">
  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">Frontend</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {FRONTEND.map(({ name, icon: Icon }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg">
          <Icon class="size-6 text-blue-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>

  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">Backend</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {BACKEND.map(({ name, icon: Icon }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg">
          <Icon class="size-6 text-green-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>

  <div>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">Herramientas Generales</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {TOOLS.map(({ name, icon: Icon }) => (
        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 p-3 rounded-lg">
          <Icon class="size-6 text-purple-500" />
          <span class="text-gray-800 dark:text-gray-200">{name}</span>
        </div>
      ))}
    </div>
  </div>
</div>