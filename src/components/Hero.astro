---
const personalImageAlt = "Ismael Bahmane Rodriguez"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import DownloadIcon from "@/components/icons/Download.astro"
import SocialPill from "@/components/SocialPill.astro"
import { t } from "../lib/translations"

const lang = Astro.url.pathname.includes("/eng") ? "en" : "es";
const resumeFile = lang === "es" 
  ? "/Currículum - Ismael Bahmane Rodriguez.pdf" 
  : "/Resume - Ismael Bahmane Rodriguez.pdf";
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="/me.jpg"
      alt={personalImageAlt}
    />
    <a
      href="https://www.linkedin.com/in/ismael-bahmane-rodriguez-83332424a"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge data-i18n-key="hero.available">{t(lang, "hero.available")}</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
    data-i18n-key="hero.greeting"
  >
    {t(lang, "hero.greeting")}
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
    data-i18n-key="hero.description"
  >
    {t(lang, "hero.description")}
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href={resumeFile} download={resumeFile}>
      <DownloadIcon class="size-4" />
      <span data-i18n-key="hero.downloadResume">{t(lang, "hero.downloadResume")}</span>
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/ismael-bahmane-rodriguez-83332424a">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="mailto:ismabytes@gmail.com">
      <MailIcon class="size-4" />
      <span data-i18n-key="hero.contactMe">{t(lang, "hero.contactMe")}</span>
    </SocialPill>
  </nav>
</div>
